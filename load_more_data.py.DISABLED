    {'symbol': 'CVX', 'name': 'Mike Wirth', 'role': 'CEO', 'type': 'BUY', 'shares': 55000, 'price': 165.00},
    {'symbol': 'COP', 'name': 'Ryan Lance', 'role': 'CEO', 'type': 'BUY', 'shares': 40000, 'price': 122.00},
    {'symbol': 'EOG', 'name': 'Bill Thomas', 'role': 'CEO', 'type': 'BUY', 'shares': 50000, 'price': 138.00},
    {'symbol': 'MPC', 'name': 'Andjelkovic', 'role': 'CEO', 'type': 'BUY', 'shares': 30000, 'price': 95.00},
    
