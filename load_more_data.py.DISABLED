    {'symbol': 'RTX', 'name': 'Jim Ryan', 'role': 'CFO', 'type': 'BUY', 'shares': 35000, 'price': 418.00},
    {'symbol': 'LMT', 'name': 'James Taiclet', 'role': 'CEO', 'type': 'BUY', 'shares': 50000, 'price': 485.00},
