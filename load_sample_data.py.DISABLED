        'reasoning': 'Boeing recovery in progress but regulatory risks remain.'
    },
    {
        'symbol': 'UEC',
        'rating': 'BUY',
        'price_target': 8.50,
        'analyst': 'Nuclear Analyst',
        'firm': 'Evercore ISI',
        'reasoning': 'Nuclear energy renaissance. Long-term uranium demand tailwind.'
    },
]

for pick in analyst_picks:
    try:
        existing = db.query(AlphaPick).filter(
            AlphaPick.symbol == pick['symbol'],
            AlphaPick.analyst == pick['analyst']
        ).first()
        
        if not existing:
            alpha_pick = AlphaPick(
                symbol=pick['symbol'],
                rating=pick['rating'],
                price_target=Decimal(str(pick['price_target'])),
                analyst_name=pick['analyst'],
                firm=pick['firm'],
                date=datetime.utcnow(),
                reasoning=pick['reasoning'],
                confidence=0.75
            )
            db.add(alpha_pick)
            print(f"  ✅ {pick['symbol']}: {pick['rating']} - Target ${pick['price_target']} ({pick['analyst']})")
    except Exception as e:
        print(f"  ⚠️  Error: {str(e)[:50]}")

db.commit()

# ============================================================================
# DONE
# ============================================================================

print("\n" + "="*50)
print("✅ SAMPLE DATA LOADED SUCCESSFULLY!")
print("="*50)
print(f"\n📊 Data Summary:")

insider_count = db.query(InsiderTrade).count()
price_count = db.query(PriceSnapshot).count()
picks_count = db.query(AlphaPick).count()

print(f"  • Insider Trades: {insider_count}")
print(f"  • Price Snapshots: {price_count}")
print(f"  • Analyst Picks: {picks_count}")
print(f"\n🚀 Now generate signals with real data!")

db.close()