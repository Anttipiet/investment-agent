# ============================================================================
# LOAD NEWS
# ============================================================================

added = 0
for news in news_data:
    try:
        existing = db.query(NewsArticle).filter(
            NewsArticle.symbol == news['symbol'],
            NewsArticle.title == news['title']
        ).first()
        
        if not existing:
            article = NewsArticle(
                symbol=news['symbol'],
                title=news['title'],
                description=news['description'],
                url=f"https://news.example.com/{news['symbol']}/{news['title'].replace(' ', '-')}",
                source=news['source'],
                sentiment=news['sentiment'],
                sentiment_score=news['sentiment_score'],
                category=news['category'],
                relevance_score=news['relevance'],
                published_at=datetime.utcnow() - timedelta(days=news['days_ago'])
            )
            db.add(article)
            added += 1
            
            emoji = "📈" if news['sentiment'] == 'POSITIVE' else "📉"
            print(f"{emoji} {news['symbol']:6} | {news['sentiment']:8} | {news['title'][:50]}")
    except Exception as e:
        print(f"⚠️  Error: {str(e)[:50]}")

db.commit()

print(f"\n✅ Added {added} news articles\n")

# ============================================================================
# SUMMARY
# ============================================================================

from models import NewsArticle as NA
positive = db.query(NA).filter(NA.sentiment == 'POSITIVE').count()
negative = db.query(NA).filter(NA.sentiment == 'NEGATIVE').count()

